{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "format": "email", "description": "The email address of the user" },
        "displayName": { "type": "string", "description": "The name the user wants to display" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the user account was last updated" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "FileEntry": {
      "title": "File",
      "description": "Metadata for a file stored in the vault",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "folder"] },
        "size": { "type": "number" },
        "content": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of parent folder or 'root'" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "ownerId", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A personal note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Information about a team member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "users/{userId}/files/{fileId}": {
      "schema": "FileEntry",
      "description": "User specific files"
    },
    "users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User specific notes"
    },
    "users/{userId}/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "User specific team members"
    }
  }
}
