rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Phase 4: Entity Validation Blueprints
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) && data.keys().size() <= 5);
    }

    function isValidFile(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.type in ['file', 'folder'] &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidNote(data) {
      return data.title is string && data.title.size() <= 256 &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidTeamMember(data) {
      return data.name is string && data.name.size() <= 256 &&
             data.email is string && data.email.size() <= 256 &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // Collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isVerified() &&
                      isValidUser(incoming()) && 
                      incoming().uid == request.auth.uid &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && 
                      isVerified() &&
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt']);

      match /files/{fileId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFile(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidFile(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId);
      }

      match /notes/{noteId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNote(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidNote(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId);
      }

      match /teamMembers/{memberId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTeamMember(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidTeamMember(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
